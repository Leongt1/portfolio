# Supabase — contact form storage (server-only, never exposed to the client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-secret-or-service-role-key

# Upstash Redis — global like counter (falls back to per-device local mode
# in production if unset; dev uses an in-memory counter)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Secret for signing the "already liked" httpOnly cookie — any long random string
LIKE_COOKIE_SECRET=change-me-to-a-long-random-string
